<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Private Notes Box</title>

<style>
    body{
        font-family: Arial, sans-serif;
        background:#111827;
        color:white;
        display:flex;
        justify-content:center;
        align-items:center;
        min-height:100vh;
        margin:0;
    }

    .container{
        width:90%;
        max-width:700px;
        background:#1f2937;
        padding:20px;
        border-radius:15px;
        box-shadow:0 0 20px rgba(0,0,0,0.4);
    }

    h1{
        text-align:center;
    }

    textarea{
        width:100%;
        height:180px;
        border:none;
        border-radius:10px;
        padding:10px;
        resize:none;
        font-size:16px;
        margin-top:10px;
    }

    input{
        width:100%;
        padding:12px;
        border:none;
        border-radius:10px;
        margin-top:10px;
        font-size:16px;
    }

    button{
        width:100%;
        padding:12px;
        margin-top:10px;
        border:none;
        border-radius:10px;
        background:#3b82f6;
        color:white;
        font-size:16px;
        cursor:pointer;
    }

    button:hover{
        background:#2563eb;
    }

    .savedBox{
        background:#111827;
        padding:15px;
        border-radius:10px;
        margin-top:15px;
        border:1px solid #374151;
    }

    .time{
        color:#9ca3af;
        font-size:14px;
        margin-bottom:10px;
    }

    .hidden{
        display:none;
    }
</style>
</head>
<body>

<div class="container">

    <h1>🔒 Private Notes</h1>

    <div id="setupArea">
        <input type="password" id="setPassword" placeholder="Set your password">
        <textarea id="noteInput" placeholder="Write your secret information here..."></textarea>
        <button onclick="saveNote()">Save Note</button>
    </div>

    <div id="openArea" class="hidden">
        <input type="password" id="enterPassword" placeholder="Enter password">
        <button onclick="openNote()">Open Saved Note</button>
    </div>

    <div id="displayArea"></div>

</div>

<script>

if(localStorage.getItem("savedPassword")){
    document.getElementById("setupArea").classList.add("hidden");
    document.getElementById("openArea").classList.remove("hidden");
}

function saveNote(){

    const password = document.getElementById("setPassword").value;
    const note = document.getElementById("noteInput").value;

    if(password === "" || note === ""){
        alert("Please fill everything.");
        return;
    }

    const currentTime = new Date().toLocaleString();

    localStorage.setItem("savedPassword", password);
    localStorage.setItem("savedNote", note);
    localStorage.setItem("savedTime", currentTime);

    alert("Note saved successfully!");

    document.getElementById("setupArea").classList.add("hidden");
    document.getElementById("openArea").classList.remove("hidden");
}

function openNote(){

    const enteredPassword = document.getElementById("enterPassword").value;
    const savedPassword = localStorage.getItem("savedPassword");

    if(enteredPassword === savedPassword){

        const note = localStorage.getItem("savedNote");
        const time = localStorage.getItem("savedTime");

        document.getElementById("displayArea").innerHTML = `
            <div class="savedBox">
                <div class="time">Saved on: ${time}</div>
                <div>${note}</div>
            </div>
        `;

    } else {
        alert("Wrong password!");
    }
}

</script>

</body>
</html>
